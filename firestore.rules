rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) || 
             (request.resource.data[field] is string && 
              request.resource.data[field].size() >= minLen && 
              request.resource.data[field].size() <= maxLen);
    }
    
    function isValidTransaction(data) {
      return hasOnlyAllowedFields(['type', 'category', 'amount', 'date', 'description', 'payment_method', 'users', 'userId', 'createdAt']) &&
             data.type in ['income', 'expense'] &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.amount is number &&
             data.date is string && data.date.size() == 10 &&
             isValidOptionalString('description', 0, 500) &&
             isValidOptionalString('payment_method', 0, 100) &&
             data.users is list &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }
    
    function isValidMember(data) {
      return hasOnlyAllowedFields(['name', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }
    
    function isValidCategory(data) {
      return hasOnlyAllowedFields(['type', 'name', 'userId', 'createdAt']) &&
             data.type in ['income', 'expense'] &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['name', 'email', 'userId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string &&
             data.userId == request.auth.uid &&
             data.createdAt is string;
    }

    match /transactions/{transactionId} {
      allow read: if isOwner();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && uidUnchanged();
      allow update: if isOwner() && isValidTransaction(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner();
    }
    
    match /categories/{categoryId} {
      allow read: if isOwner();
      allow create: if isAuthenticated() && isValidCategory(request.resource.data) && uidUnchanged();
      allow update: if isOwner() && isValidCategory(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner();
    }

    match /members/{memberId} {
      allow read: if isOwner();
      allow create: if isAuthenticated() && isValidMember(request.resource.data) && uidUnchanged();
      allow update: if isOwner() && isValidMember(request.resource.data) && uidNotModified() && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
    }
  }
}
